# Uniguard Pro Bridge — environment overrides
# The only REQUIRED variable for first boot is UGBRIDGE_TUNNEL_TOKEN.

# Cloud API endpoint
# UGBRIDGE_CLOUD_API_URL=https://olzhvzijbmaeqxbmemgt.supabase.co/functions/v1/bridge-api

# Tunnel token (REQUIRED for first-time registration)
UGBRIDGE_TUNNEL_TOKEN=

# Network binding
UGBRIDGE_HOST=0.0.0.0
UGBRIDGE_PORT=8080

# HLS output directory
UGBRIDGE_HLS_DIR=/tmp/hls

# Local state file (stores clientId after registration)
# UGBRIDGE_STATE_FILE=/opt/uniguard-bridge/state.json

# Stream idle timeout (seconds)
UGBRIDGE_STREAM_TIMEOUT_SECONDS=300

# FFmpeg settings
# UGBRIDGE_FFMPEG_PATH=/usr/bin/ffmpeg
UGBRIDGE_HLS_SEGMENT_TIME=2
UGBRIDGE_HLS_LIST_SIZE=5

# Cloud polling intervals
UGBRIDGE_CONFIG_POLL_INTERVAL=60
UGBRIDGE_HEARTBEAT_INTERVAL=30
